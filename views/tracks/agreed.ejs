<%- include('../partials/header') %>

<main class="page-container">
    <div class="card agreed-card">
        <div class="agreed-content">
            <div class="agreed-icon">✅</div>
            <h1>Agreement Signed!</h1>
            <p>Thanks, <strong><%= collaborator.name %></strong>!</p>
            <p class="text-muted">You've signed the agreement for "<%= track.title %>"</p>
            
            <% if (collaborator.signature) { %>
                <div class="signature-display">
                    <p>Your signature:</p>
                    <img src="<%= collaborator.signature %>" alt="Your Signature" class="signature-image">
                </div>
            <% } %>

            <div class="agreed-details">
                <p><strong>Signed on:</strong> <%= new Date(collaborator.agreedAt).toLocaleString() %></p>
            </div>
            
            <% if (track.allAgreed) { %>
                <div class="all-agreed-notice">
                    <h3>🎉 All Parties Have signed!</h3>
                    <p>This split sheet is now locked and finalized.</p>
                </div>
            <% } else { %>
                <div class="waiting-notice">
                    <p>Waiting for other collaborators to sign...</p>
                </div>
            <% } %>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>