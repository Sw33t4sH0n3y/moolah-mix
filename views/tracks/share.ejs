<%- include('../partials/header') %>

<main class="page-container">
    <div class="card share-card">
        <div class="share-header">
            <h1>📄 Split Sheet</h1>
            <p class="text-muted">for "<%= track.title %>"</p>
        </div>

        <div class="share-meta">
            <% if (track.releaseDate) { %>
                <span>📅 <%= new Date(track.releaseDate).toLocaleDateString() %></span>
            <% } %>
            <% if (track.isrc) { %>
                <span>🔖 ISRC: <%= track.isrc %></span>
            <% } %>
        </div>

        <hr class="form-divider">

        <!-- Owner -->
        <section class="share-section">
            <h2>👑 Owner</h2>
            <div class="share-person">
                <div class="share-avatar"><%= (owner.displayName || owner.username || 'U').charAt(0).toUpperCase() %></div>
                <div class="share-info">
                    <div class="share-name"><%= owner.displayName || owner.username %></div>
                    <div class="share-splits">
                        <span>🎵 Master: <%= track.splits?.master?.owner || 100 %>%</span>
                        <span>📝 Publishing: <%= track.splits?.publishing?.owner || 100 %>%</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Collaborators -->
        <% if (track.collaborators && track.collaborators.length > 0) { %>
            <section class="share-section">
                <h2>👥 Collaborators</h2>
                <% track.collaborators.forEach(collab => { %>
                    <% const collabId = collab._id.toString(); %>
                    <% const masterPct = track.splits?.master?.collaborators?.get(collabId) || 0; %>
                    <% const pubPct = track.splits?.publishing?.collaborators?.get(collabId) || 0; %>
                    
                    <div class="share-person">
                        <div class="share-avatar"><%= collab.name.charAt(0).toUpperCase() %></div>
                        <div class="share-info">
                            <div class="share-name"><%= collab.name %></div>
                            <div class="share-roles">
                                <% if (collab.roles && collab.roles.length > 0) { %>
                                    <% collab.roles.forEach(role => { %>
                                        <% if (ROLES && ROLES[role]) { %>
                                            <span class="role-badge role-badge-<%= role %>">
                                                <%= ROLES[role].icon %> <%= ROLES[role].label %>
                                            </span>
                                        <% } %>
                                    <% }) %>
                                <% } %>
                            </div>
                            <div class="share-splits">
                                <span>🎵 Master: <%= masterPct %>%</span>
                                <span>📝 Publishing: <%= pubPct %>%</span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </section>
        <% } %>

        <hr class="form-divider">

        <!-- Totals -->
        <section class="share-section">
            <h2>📊 Totals</h2>
            <% 
                let masterTotal = track.splits?.master?.owner || 100;
                let pubTotal = track.splits?.publishing?.owner || 100;
                if (track.collaborators && track.splits) {
                    track.collaborators.forEach(c => {
                        masterTotal += track.splits?.master?.collaborators?.get(c._id.toString()) || 0;
                        pubTotal += track.splits?.publishing?.collaborators?.get(c._id.toString()) || 0;
                    });
                }
            %>
            <div class="share-totals">
                <div class="share-total-item">
                    <span>🎵 Master Recording</span>
                    <span class="<%= masterTotal === 100 ? 'valid' : 'invalid' %>"><%= masterTotal %>%</span>
                </div>
                <div class="share-total-item">
                    <span>📝 Publishing</span>
                    <span class="<%= pubTotal === 100 ? 'valid' : 'invalid' %>"><%= pubTotal %>%</span>
                </div>
            </div>
        </section>

        <div class="share-footer">
            <p class="text-muted">Generated by Moolah M$x on <%= new Date().toLocaleDateString() %></p>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>