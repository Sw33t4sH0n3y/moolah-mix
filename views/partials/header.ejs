<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/style.css" />
    <link rel="icon" href="/images/Moolah_Mix_Logo.png" type="image/jpeg">
    <title>Moolah M$X | Stack Your Splits, Secure Your Bag</title>
  </head>
  <body>

    <div class="beta-banner">
        🚀 Beta Version — Free during testing! <a href="https://forms.gle/uN1wUfhQfyyCfG5E6" target="_blank">Give Feedback</a>
    </div>
    <header class="main-header">
      <div class="header-content">
        <a href="/" class="logo">
          <img src="/images/Moolah_Mix_Logo.png" alt="Moolah M$X" class="logo-image">
        </a>

        <nav class="main-nav">
          <button class="theme-toggle" onclick="toggleTheme()" title="Toggle dark/light mode">🌙</button>
          <% if (typeof user !== 'undefined' && user) { %>
            <a href="/tracks" class="nav-link">My Songs</a>
            <a href="/hub" class="nav-link">Hub</a>
            <span class="user-avatar"><%= user.displayName ? user.displayName.charAt(0).toUpperCase() : 'U' %></span>
            <a href="/auth/sign-out" class="btn btn-secondary btn-small">Sign Out</a>
          <% } else { %>
            <a href="/auth/sign-in" class="nav-link">Sign In</a>
            <a href="/auth/sign-up" class="btn btn-primary">Sign Up</a>
          <% } %>
        </nav>
      </div>
    </header>

    <script>
      function toggleTheme() {
        document.body.classList.toggle('light-mode');
        var isLight = document.body.classList.contains('light-mode');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        document.querySelector('.theme-toggle').textContent = isLight ? '☀️' : '🌙';
      }

      if (localStorage.getItem('theme') === 'light') {
        document.body.classList.add('light-mode');
        document.querySelector('.theme-toggle').textContent = '☀️';
      }
    </script>