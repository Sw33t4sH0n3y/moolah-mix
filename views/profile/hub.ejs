<%- include('../partials/header') %>

<main class="hub-page">
    <div class="page-container">
        
        <!-- Welcome Card with Stats -->
        <div class="welcome-card">
            <div class="welcome-header">
                <div class="welcome-avatar">
                    <%= user.displayName ? user.displayName.charAt(0).toUpperCase() : 'U' %>
                </div>
                <div class="welcome-text">
                    <h1>Welcome back, <%= user.displayName || user.username %>!</h1>
                    <p>
                        <% if (user.stageName) { %><%= user.stageName %> • <% } %>
                        <% if (user.roles && user.roles.length > 0) { %>
                            <% user.roles.forEach(function(r, i) { %>
                                <%= ROLES[r] ? ROLES[r].label : r %><%= i < user.roles.length - 1 ? ', ' : '' %>
                            <% }) %>
                        <% } else { %>
                            Artist
                        <% } %>
                    </p>
                </div>
            </div>
            
            <div class="welcome-stats">
                <div class="welcome-stat">
                    <div class="welcome-stat-value"><%= typeof trackCount !== 'undefined' ? trackCount : 0 %></div>
                    <div class="welcome-stat-label">Songs</div>
                </div>
                <div class="welcome-stat">
                    <div class="welcome-stat-value green"><%= typeof collabCount !== 'undefined' ? collabCount : 0 %></div>
                    <div class="welcome-stat-label">Collaborators</div>
                </div>
                <div class="welcome-stat">
                    <div class="welcome-stat-value"><%= typeof pendingCount !== 'undefined' ? pendingCount : 0 %></div>
                    <div class="welcome-stat-label">Pending</div>
                </div>
            </div>
            
            <div class="welcome-actions">
                <a href="/tracks/new" class="btn btn-primary">+ New Song</a>
                <a href="/tracks" class="btn btn-secondary">View All Songs</a>
            </div>
        </div>

        <!-- Profile Settings Card -->
        <div class="card hub-card">
            <div class="card-header">
                <h2>User Deets</h2>
            </div>
            
            <form action="/hub?_method=PUT" method="POST">

                <section class="form-section">
                    <div class="form-group">
                        <label for="displayName">Display Name</label>
                        <input type="text" id="displayName" name="displayName" value="<%= user.displayName || '' %>" placeholder="Your display name">
                    </div>

                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" value="<%= user.username %>" disabled>
                        <span class="form-hint">Username cannot be changed</span>
                    </div>
                </section>

                <section class="form-section">
                    <h2 class="section-heading">Your Roles</h2>
                    <p class="section-description">Select all that apply</p>

                    <div class="role-buttons">
                        <% Object.entries(ROLES).forEach(function([key, role]) { %>
                            <% const isChecked = user.roles && user.roles.includes(key); %>
                            <label class="role-checkbox">
                                <input type="checkbox" name="roles" value="<%= key %>" <%= isChecked ? 'checked' : '' %>>
                                <span class="role-btn <%= isChecked ? 'selected' : '' %>"> 
                                    <%= role.icon %> <%= role.label %>
                                </span>
                            </label>
                        <% }) %>
                    </div>
                </section>

                <!-- Artist Fields -->
                <div class="role-fields role-fields-artist hidden" id="artist-fields">
                    <h3>🎤 Artist Deets</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="stageName">Stage Name</label>
                            <input type="text" id="stageName" name="stageName" value="<%= user.stageName || '' %>">
                        </div>
                        <div class="form-group">
                            <label for="genre">Genre</label>
                            <input type="text" id="genre" name="genre" value="<%= user.genre || '' %>">
                        </div>
                    </div>
                </div>

                <!-- Producer Fields -->
                <div class="role-fields role-fields-producer hidden" id="producer-fields">
                    <h3>🎛️ Producer Deets</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="producerTag">Producer Tag</label>
                            <input type="text" id="producerTag" name="producerTag" value="<%= user.producerTag || '' %>">
                        </div>
                        <div class="form-group">
                            <label for="daw">DAW</label>
                            <select id="daw" name="daw">
                                <option value="">Select DAW</option>
                                <% DAW_OPTIONS.forEach(function(d) { %>
                                    <option value="<%= d %>" <%= user.daw === d ? 'selected' : '' %>><%= d %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>    
                </div>

                <!-- Writer Fields -->
                <div class="role-fields role-fields-writer hidden" id="writer-fields">
                    <h3>✍️ Writer Deets</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="writerPro">PRO</label>
                            <select id="writerPro" name="writerPro">
                                <option value="">Select PRO</option>
                                <% PRO_OPTIONS.forEach(function(p) { %>
                                    <option value="<%= p %>" <%= user.writerPro === p ? 'selected' : '' %>><%= p %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="writerIpi">IPI Number</label>
                            <input type="text" id="writerIpi" name="writerIpi" value="<%= user.writerIpi || '' %>">
                        </div>
                    </div>
                </div>

                <!-- Publisher Fields -->
                <div class="role-fields role-fields-publisher hidden" id="publisher-fields">
                    <h3>📄 Publisher Deets</h3>
                    <div class="form-group">
                        <label for="publishingCompany">Publishing Company</label>
                        <input type="text" id="publishingCompany" name="publishingCompany" value="<%= user.publishingCompany || '' %>">
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="publisherPro">Publisher PRO</label>
                            <select id="publisherPro" name="publisherPro">
                                <option value="">Select PRO</option>
                                <% PRO_OPTIONS.forEach(function(p) { %>
                                    <option value="<%= p %>" <%= user.publisherPro === p ? 'selected' : '' %>><%= p %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="publisherIpi">Publisher IPI</label>
                            <input type="text" id="publisherIpi" name="publisherIpi" value="<%= user.publisherIpi || '' %>">
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-large btn-full">Save Hub</button>
            </form>
        </div>
    </div>
</main>

<script>
    document.querySelectorAll('.role-checkbox input').forEach(function(checkbox) {
        checkbox.addEventListener('change', function() {
            const role = this.value;
            const fields = document.querySelector(role + '#-fields');
            const btn = this.nextElementSibling;

            if (fields) {
                if (this.checked) {
                    fields.classList.remove('hidden');
                    btn.classList.add('selected');
                } else {
                    fields.classList.add('hidden');
                    btn.classList.remove('selected');
                }
            }    
        });
    });

    // Show fields on page load if already checked
    document.querySelectorAll('.role-checkbox input:checked').forEach(function(checkbox) {
        const role = checkbox.value;
        const fields = document.querySelector(role + '#-fields');
        if (fields) {
            fields.classList.remove('hidden');
        }
    });
</script>

<%- include('../partials/footer') %>